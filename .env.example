# Era 1 (Obsidian/Jekyll) source: local clone of github.com/weaties/blog
OBSIDIAN_REPO_PATH=./sources/blog
# Public base used to hotlink Era-1 attachments (no upload). Match the repo's default branch.
OBSIDIAN_RAW_BASE=https://raw.githubusercontent.com/weaties/blog/main

# Reconcile target: a Ghost "Migration tools -> Export" JSON of the current site.
# Used to skip posts already in Ghost. Override per-run with --against=<file>.
GHOST_EXPORT_PATH=./sources/ghost-export.json

# --- Phase 2: Ghost -> Obsidian vault mirror ---
# Public Ghost site URL — used to resolve the "__GHOST_URL__" placeholder in exports.
GHOST_SITE_URL=https://weaties.ghost.io
# PRIVATE mirror dir, INSIDE your personal Obsidian vault. NEVER commit this path;
# Claude/LLMs must never read it. Only launchd-run scripts write here.
VAULT_DIR=/Users/you/ObsidianVault/blog-mirror
# Durable archive of raw Ghost exports (sparse retention: oldest kept forever).
# Keep private like the vault. If unset, the launchd wrapper skips archiving.
ARCHIVE_DIR=/Users/you/ghost-exports

# Folder watched for fresh Ghost exports (the browser drops them here on Export).
# The launchd watch agent ingests any new *ghost*.json found here. Default ~/Downloads.
# WATCH_DIR=/Users/you/Downloads

# Optional: staff login for SCRIPTED export (ghost-vault fetch-export). Mostly moot:
# with Ghost(Pro) staff 2FA enabled (default), scripted login is blocked by an emailed
# code, so the watch-Downloads agent is the reliable path. SENSITIVE — never commit.
# GHOST_ADMIN_EMAIL=you@example.com
# GHOST_ADMIN_PASSWORD=your-ghost-password

# Era 2 (WordPress.com) source: path to a WXR export file (Tools -> Export)
WP_WXR_PATH=./sources/wordpress-export.xml
WP_SITE_URL=https://weatiesroadtrip2021.com

# --- Optional: only needed if the Ghost site is ever upgraded to a tier with the
# --- Admin API (custom integrations). Unused by the default Starter-plan flow.
# GHOST_ADMIN_API_URL=https://weaties.ghost.io
# GHOST_ADMIN_API_KEY=<id>:<secret>
# GHOST_API_VERSION=v5.0
